{
  "schemaVersion": 1,
  "id": "dungeonterminalmap",
  "version": "${version}",
  "name": "DungeonTerminalMap",
  "description": "Terminal phase class-assignment HUD map for SkyBlock dungeons.",
  "authors": ["krister"],
  "license": "MIT",
  "environment": "client",
  "entrypoints": {
    "client": [
      {
        "value": "dev.krister.dungeonterminalmap.DungeonTerminalMapAddon",
        "adapter": "kotlin"
      }
    ]
  },
  "mixins": [
    "dungeonterminalmap.mixins.json"
  ],
  "depends": {
    "fabricloader": ">=0.19.3",
    "minecraft": "~26.1-",
    "java": ">=25",
    "fabric-api": "*",
    "fabric-language-kotlin": "*",
    "devonian": ">=1.25.9"
  }
}
